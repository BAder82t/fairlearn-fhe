include LICENSE
include pyproject.toml
include README.md
include SECURITY.md
include CONTRIBUTING.md
include mkdocs.yml

recursive-include docs *.md
recursive-include examples *.py
recursive-include benchmarks *.py
recursive-include tests *.py

prune dist
prune site
prune .github
prune .pytest_cache
global-exclude __pycache__ *.py[cod]
